# Each app (nexus-analytics/, nexus-admin/, analytics_engine/) also has its
# own .gitignore for framework-specific artifacts — these are repo-wide catch-alls.

# Secrets — never commit real env values, only .env.example files
.env
.env.local
.env.*.local
*.pem
*.key

# Dependencies / build artifacts
node_modules/
.next/
out/
build/
dist/
__pycache__/
*.pyc
.venv/
venv/

# Logs
*.log

# OS / editor
.DS_Store
Thumbs.db
