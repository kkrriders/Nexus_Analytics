# ── ClickHouse Cloud ──────────────────────────────────────────────────────────
CLICKHOUSE_HOST=
CLICKHOUSE_USER=
CLICKHOUSE_PASSWORD=
CLICKHOUSE_SECURE=true

# ── DeepSeek AI (recommendations + chatbot) ──────────────────────────────────
DEEPSEEK_API_KEY=

# ── Supabase Postgres (user accounts / auth) ─────────────────────────────────
SUPABASE_DB_HOST=
SUPABASE_DB_PORT=5432
SUPABASE_DB_NAME=postgres
SUPABASE_DB_USER=postgres
SUPABASE_DB_PASSWORD=
SUPABASE_DB_SSLMODE=require

# ── Supabase Auth API (JWT verification, admin user management) ─────────────
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ── n8n shared secret (X-N8N-Secret header) ──────────────────────────────────
# Set the same value in n8n's HTTP Request node headers so the workflows can
# call the /api/accounts/* and /api/ingest/* endpoints.
N8N_SHARED_SECRET=

# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated list of origins allowed to call this API. Add the deployed
# Vercel frontend domain and the separate admin panel domain here.
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# ── n8n (bundled in the same container — see Dockerfile/supervisord.conf) ───
# n8n stores workflows/credentials/execution history in Postgres instead of
# its default SQLite file, since Render's filesystem is wiped on redeploy
# without a paid persistent disk. Point it at the SAME Supabase Postgres
# values as SUPABASE_DB_* above (duplicate the literal values here — these
# are read by n8n directly, not resolved from the other vars).
DB_TYPE=postgresdb
DB_POSTGRESDB_HOST=
DB_POSTGRESDB_PORT=5432
DB_POSTGRESDB_DATABASE=postgres
DB_POSTGRESDB_USER=postgres
DB_POSTGRESDB_PASSWORD=
DB_POSTGRESDB_SCHEMA=n8n
DB_POSTGRESDB_SSL_ENABLED=true
# Must stay constant across restarts/redeploys or n8n cannot decrypt stored
# credentials — generate once (e.g. `openssl rand -hex 32`) and never rotate.
N8N_ENCRYPTION_KEY=
# Basic auth for the n8n editor UI at /n8n/ (Render service has no other login gate).
N8N_BASIC_AUTH_ACTIVE=true
N8N_BASIC_AUTH_USER=
N8N_BASIC_AUTH_PASSWORD=
