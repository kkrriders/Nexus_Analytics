# ── ClickHouse Cloud ──────────────────────────────────────────────────────────
CLICKHOUSE_HOST=
CLICKHOUSE_USER=
CLICKHOUSE_PASSWORD=
CLICKHOUSE_SECURE=true

# ── DeepSeek AI (recommendations + chatbot) ──────────────────────────────────
DEEPSEEK_API_KEY=

# ── Supabase Postgres (user accounts / auth) ─────────────────────────────────
SUPABASE_DB_HOST=
SUPABASE_DB_PORT=5432
SUPABASE_DB_NAME=postgres
SUPABASE_DB_USER=postgres
SUPABASE_DB_PASSWORD=
SUPABASE_DB_SSLMODE=require

# ── Supabase Auth API (JWT verification, admin user management) ─────────────
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ── n8n shared secret (X-N8N-Secret header) ──────────────────────────────────
# Only needed if you also run n8n locally/elsewhere for optional extra
# automation — the live dashboard no longer depends on n8n (see
# integrations/meta_ads.py, which fetches directly on a schedule/on-demand).
# Set the same value in n8n's HTTP Request node headers if you use it.
N8N_SHARED_SECRET=

# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated list of origins allowed to call this API. Add the deployed
# Vercel frontend domain and the separate admin panel domain here.
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
